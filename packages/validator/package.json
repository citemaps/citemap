{
  "name": "@citemap/validator",
  "version": "0.3.1",
  "description": "Validate citemap.json files — schema checks, quality scoring, level assessment, field diagnostics",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "citemap",
    "validator",
    "json-schema",
    "aeo"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/citemaps/citemap"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "@citemap/schema": "^0.3.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
