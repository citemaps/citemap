{
  "name": "@citemap/cli",
  "version": "0.3.4",
  "description": "Command-line tool for validating citemap.json files",
  "bin": {
    "citemap": "bin/citemap.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --no-dts --out-dir dist",
    "dev": "node --loader ts-node/esm src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "citemap",
    "cli",
    "validator",
    "ai",
    "citation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/citemaps/citemap"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@citemap/validator": "^0.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
